    # Импортирован из scripts/builtin_sources.py
    builtin_urls = BUILTIN_URLS

    # добавляем встроенный список как отдельную группу источников
    sources_cfg.setdefault("mirror_url_list", [])
    for i, url in enumerate(builtin_urls, 1):
        sources_cfg["mirror_url_list"].append(
